<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
	<xs:element name="UBFBilgileri">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="UBFGenelBilgiler">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="BelgeNo" type="xs:string" minOccurs="0"/>	<!--Sadece export icin eklendi, import ederken bu alana bakilmaz-->
							<xs:element name="DisReferansNo" minOccurs="0"><!--Firmaların sbup dışı sbiflerini takip edebilmeleri için eklendi-->
							  <xs:simpleType>
								<xs:restriction base="xs:string">
								  <xs:minLength value="0"/>
								  <xs:maxLength value="30"/>
								</xs:restriction>
							  </xs:simpleType>
							</xs:element>
							<xs:element name="SerbestBolgeAdi" type="serbestBolgeType"/>
							<xs:element name="FirmaFaaliyetRuhsatiNo">
							  <xs:simpleType>
								<xs:restriction base="xs:string">
								  <xs:minLength value="1"/>
								  <xs:maxLength value="32"/>
								</xs:restriction>
							  </xs:simpleType>
							</xs:element>
							<xs:element name="FirmaFaaliyetRuhsatiKonusu" type="ruhsatKonulariType"/>
							<xs:element name="GirisTarihi" type="CSDateType" minOccurs="0"/>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
				<xs:element name="UrunBilgileri" maxOccurs="unbounded">
					<xs:complexType>
						<xs:sequence>
							<xs:element name="Urun">
								<xs:complexType>
									<xs:sequence>
										<xs:element name="SiraNo" type="xs:int" minOccurs="0"/><!--Sadece export icin eklendi, import ederken bu alana bakilmaz-->
										<xs:element name="gtip">
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:pattern value="[0-9]{12}"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="UrunAdi">
										  <xs:simpleType>
											<xs:restriction base="xs:string">
											  <xs:minLength value="1"/>
											  <xs:maxLength value="50"/>
											</xs:restriction>
										  </xs:simpleType>
										</xs:element>
										<xs:element name="BirinciMiktar">
											<xs:simpleType>
												<xs:restriction base="xs:decimal">
													<xs:minInclusive value="0.001"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="BirinciBirim" type="olcuBirimiType"/>
										<xs:element name="IkinciMiktar" type="xs:decimal" minOccurs="0"/>
										<xs:element name="IkinciBirim" type="olcuBirimiType" minOccurs="0"/>
										<xs:element name="UcuncuMiktar" type="xs:decimal" minOccurs="0"/>
										<xs:element name="UcuncuBirim" type="olcuBirimiType" minOccurs="0"/>
										<xs:element name="UrunMensei" type="ulkeType"/>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
							<xs:element name="HamMadde" minOccurs="0" maxOccurs="unbounded">
								<xs:complexType>
									<xs:sequence>
										<!--referans olarak kullanılan malkalem veya Urun bilgisinin SBBUP sistemindeki tekil numarası, 
										    eger kullanıcı tarafından biliniyorsa , verilmesi gerekmektedir-->
										<xs:element name="ReferansFormTipi" type="formTipiType"/>
										<!-- ReferansFormNo alanında kullanılacak örnek veriler:
											 stok ilk giriş 	: -45 
											 SBIF/UBF/Ayniyat	: 1433
											 Stok Dönüşüm 		: [DNSM]6
										-->
										<xs:element name="ReferansFormNo">
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:minLength value="1"/>
													<xs:maxLength value="32"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>										
										<xs:element name="ReferansFormYil">
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:pattern value="[0-9]{4}"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>	
										<xs:element name="ReferansSiraNo" type="xs:int"/>
										<xs:element name="gtip">
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:pattern value="[0-9]{12}"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="Cins">
											<xs:simpleType>
												<xs:restriction base="xs:string">
													<xs:minLength value="1"/>
													<xs:maxLength value="30"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>										
										<xs:element name="Mensei" type="ulkeType"/>
										<xs:element name="BirinciMiktar">
											<xs:simpleType>
												<xs:restriction base="xs:decimal">
													<xs:minInclusive value="0.001"/>
												</xs:restriction>
											</xs:simpleType>
										</xs:element>
										<xs:element name="BirinciFireMiktar" type="xs:decimal" minOccurs="0"/>
										<xs:element name="BirinciBirim" type="olcuBirimiType"/>
										<xs:element name="IkinciMiktar" type="xs:decimal" minOccurs="0"/>
										<xs:element name="IkinciFireMiktar" type="xs:decimal"  minOccurs="0"/>
										<xs:element name="IkinciBirim" type="olcuBirimiType"  minOccurs="0"/>
										<xs:element name="UcuncuMiktar" type="xs:decimal"  minOccurs="0"/>
										<xs:element name="UcuncuFireMiktar" type="xs:decimal" minOccurs="0"/>
										<xs:element name="UcuncuBirim" type="olcuBirimiType"  minOccurs="0"/>
									</xs:sequence>
								</xs:complexType>
							</xs:element>
						</xs:sequence>
					</xs:complexType>
				</xs:element>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
